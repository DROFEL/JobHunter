{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "JobPosting",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "url",
    "position_name",
    "company_name",
    "posting_date",
    "description",
    "relevant_skills"
  ],
  "properties": {
    "url": {
      "type": "string",
      "format": "uri",
      "description": "The URL of the job posting."
    },
    "company_logo_url": {
      "type": "string",
      "description": "URL to the company logo"
    },
    "posting_id": {
      "type": "string",
      "description": "Internal identifier for the posting like jobid in url."
    },
    "external_id": {
      "type": "string",
      "description": "External identifier for the posting. Usually a field on the page with particular company id"
    },
    "position_name": {
      "type": "string",
      "description": "Title of the job position."
    },
    "company_name": {
      "type": "string",
      "description": "Name of the company."
    },
    "posting_date": {
      "type": "string",
      "format": "date-time",
      "description": "Posting date in ISO 8601 date-time format."
    },
    "description": {
      "type": "string",
      "description": "Full job description."
    },
    "relevant_skills": {
      "type": "array",
      "description": "List of relevant skills for the role.",
      "items": {
        "type": "string"
      },
      "minItems": 1,
      "uniqueItems": true
    }
  }
}
